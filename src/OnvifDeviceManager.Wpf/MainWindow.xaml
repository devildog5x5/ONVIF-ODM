<Window x:Class="OnvifDeviceManager.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
        xmlns:views="clr-namespace:OnvifDeviceManager.Wpf.Views"
        xmlns:conv="clr-namespace:OnvifDeviceManager.Wpf.Converters"
        Title="ONVIF Device Manager"
        Width="1400" Height="900"
        MinWidth="1100" MinHeight="700"
        Icon="pack://application:,,,/warrior_icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBg}"
        Foreground="White"
        FontFamily="{StaticResource MainFont}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:DiscoveryViewModel}"><views:DiscoveryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeviceInfoViewModel}"><views:DeviceInfoView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveViewViewModel}"><views:LiveViewView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PtzViewModel}"><views:PtzView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfilesViewModel}"><views:ProfilesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkViewModel}"><views:NetworkView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}"><views:UsersView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventsViewModel}"><views:EventsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CredentialManagerViewModel}"><views:CredentialManagerView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Background="{StaticResource SecondaryBg}" BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/branding_master.png" Width="28" Height="28"
                           Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="ONVIF Device Manager" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Discover and manage ONVIF IP cameras" FontSize="11" Foreground="{StaticResource MutedText}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedDevice.DisplayName, FallbackValue='No Device Selected'}" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Ellipse Width="8" Height="8" Fill="{StaticResource Accent}" Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="{StaticResource SecondaryBg}" BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8">
                        <TextBlock Text="DISCOVERY" FontSize="11" Foreground="{StaticResource MutedText}" FontWeight="Bold" Margin="16,12,0,6" />
                        <Button Style="{StaticResource PrimaryBtn}" Content="Scan for Devices" Command="{Binding NavigateCommand}" CommandParameter="Discovery" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" />

                        <!-- Active Device — all sections below apply to this camera only -->
                        <Border Background="#0d1a0d" CornerRadius="6" Padding="10,8" Margin="4,12,4,4" BorderBrush="#3fb950" BorderThickness="1"
                                Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVis}}">
                            <StackPanel>
                                <TextBlock Text="ACTIVE DEVICE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding SelectedDevice.DisplayName, FallbackValue='—'}" 
                                           FontSize="12" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedDevice.Address, FallbackValue=''}" 
                                           FontSize="10" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="No device selected — connect from Discovery" FontSize="10" Foreground="{StaticResource MutedText}" 
                                   Margin="12,8,8,4" TextWrapping="Wrap"
                                   Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVis}, ConverterParameter=Invert}" />

                        <TextBlock Text="DEVICE (for selected camera only)" FontSize="11" Foreground="{StaticResource MutedText}" FontWeight="Bold" Margin="16,16,0,6" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Device Info" Command="{Binding NavigateCommand}" CommandParameter="DeviceInfo" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Live View" Command="{Binding NavigateCommand}" CommandParameter="LiveView" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="PTZ Control" Command="{Binding NavigateCommand}" CommandParameter="PTZ" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Media Profiles" Command="{Binding NavigateCommand}" CommandParameter="Profiles" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />

                        <TextBlock Text="MANAGEMENT" FontSize="11" Foreground="{StaticResource MutedText}" FontWeight="Bold" Margin="16,20,0,6" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Network" Command="{Binding NavigateCommand}" CommandParameter="Network" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Users" Command="{Binding NavigateCommand}" CommandParameter="Users" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Events" Command="{Binding NavigateCommand}" CommandParameter="Events" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" IsEnabled="{Binding IsDeviceConnected}" />

                        <TextBlock Text="APPLICATION" FontSize="11" Foreground="{StaticResource MutedText}" FontWeight="Bold" Margin="16,20,0,6" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Credentials" Command="{Binding NavigateCommand}" CommandParameter="Credentials" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings" HorizontalAlignment="Stretch" Margin="4,2" Padding="14,10" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" />
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" BorderBrush="{StaticResource BorderClr}" BorderThickness="0,1,0,0" Padding="16,6">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
                <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Text="{Binding Devices.Count, StringFormat='{}{0} device(s)'}" />
            </Grid>
        </Border>
    </Grid>
</Window>
