<Application x:Class="OnvifDeviceManager.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Wpf.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Icon set in code (MainWindow) — pack URIs here can throw at parse time when BaseDirectory/package resolution fails (e.g. some publish layouts). -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:BoolToTextConverter x:Key="BoolToSubscribe" />
            <conv:NullToVisibilityConverter x:Key="NullToVis" />
            <conv:StatusToColorConverter x:Key="StatusToColor" />
            <conv:BytesToImageConverter x:Key="BytesToImage" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
