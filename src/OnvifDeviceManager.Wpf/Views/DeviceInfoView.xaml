<UserControl x:Class="OnvifDeviceManager.Wpf.Views.DeviceInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             DataContext="{Binding}"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}">

    <Grid>
        <Grid Margin="24" Visibility="{Binding Device, Converter={StaticResource NullToVis}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Device Information" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Device Details Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Device Details" FontWeight="SemiBold" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="Refresh" Command="{Binding RefreshCommand}" Margin="16,0,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Manufacturer:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.Manufacturer}" FontFamily="{StaticResource MonoFont}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Model:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.Model}" FontFamily="{StaticResource MonoFont}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Firmware:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.FirmwareVersion}" FontFamily="{StaticResource MonoFont}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Serial:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.SerialNumber}" FontFamily="{StaticResource MonoFont}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Hardware ID:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.HardwareId}" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Address:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.Address}" FontFamily="{StaticResource MonoFont}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Service URL:" Foreground="{StaticResource MutedText}" />
                                <TextBlock Grid.Column="1" Text="{Binding Device.ServiceAddress}" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="24,0,0,0">
                            <WrapPanel>
                                <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding Device.Capabilities.HasMedia, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Media" Foreground="#FF1A1A2E" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding Device.Capabilities.HasPtz, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="PTZ" Foreground="#FF1A1A2E" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding Device.Capabilities.HasEvents, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Events" Foreground="#FF1A1A2E" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding Device.Capabilities.HasImaging, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Imaging" Foreground="#FF1A1A2E" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding Device.Capabilities.HasAnalytics, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Analytics" Foreground="#FF1A1A2E" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Style="{StaticResource SecondaryBtn}" Content="Reboot" Command="{Binding RebootCommand}" Margin="0,0,8,0" />
                            <Button Style="{StaticResource DangerBtn}" Content="Factory Reset" Command="{Binding FactoryResetCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hostname Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Hostname" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox Style="{StaticResource ModernTB}" Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}" Width="280" Margin="0,0,12,0" />
                            <Button Style="{StaticResource PrimaryBtn}" Content="Set" Command="{Binding SetHostnameCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Date/Time Card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Date &amp; Time" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding DateTimeInfo.DeviceTime, StringFormat='Device Time: {0:yyyy-MM-dd HH:mm:ss}'}" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DateTimeInfo.TimeZone, StringFormat='Time Zone: {0}'}" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DateTimeInfo.IsNtp, StringFormat='NTP: {0}'}" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DateTimeInfo.NtpServer, StringFormat='NTP Server: {0}'}" Foreground="{StaticResource SecondaryText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16,10" Margin="0,16,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
        </Border>
        </Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Device, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#607D8B" HorizontalAlignment="Center" />
            <TextBlock Text="No Device Connected" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,8" />
            <TextBlock Text="To use this page:" FontSize="13" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="1. Click Discover Devices to scan your network" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="2. Select a camera from the list" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="3. Enter username and password" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="4. Click Connect" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
        </StackPanel>
    </Grid>
</UserControl>
