<UserControl x:Class="OnvifDeviceManager.Wpf.Views.LiveViewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Wpf.Converters"
             DataContext="{Binding}"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}">

    <UserControl.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImage" />
    </UserControl.Resources>

    <Grid>
        <Grid Margin="24" Visibility="{Binding Device, Converter={StaticResource NullToVis}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Live View" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Controls -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name" MinWidth="200" Margin="0,0,16,0"
                              Background="{StaticResource InputBg}" Foreground="White" BorderBrush="{StaticResource BorderClr}" />
                    <Button Style="{StaticResource PrimaryBtn}" Content="Snapshot" Command="{Binding RefreshSnapshotCommand}" Margin="0,0,8,0" />
                    <Button Style="{StaticResource SecondaryBtn}" Content="Auto Refresh" Command="{Binding StartAutoRefreshCommand}" Margin="0,0,8,0" />
                    <Button Style="{StaticResource DangerBtn}" Content="Stop" Command="{Binding StopAutoRefreshCommand}" />
                </StackPanel>
            </Border>

            <!-- Image -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                <Grid Background="{StaticResource InputBg}">
                    <Image Source="{Binding SnapshotBytes, Converter={StaticResource BytesToImage}}"
                           Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Text="No snapshot" Foreground="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SnapshotBytes, Converter={StaticResource NullToVis}, ConverterParameter=Invert}" />
                </Grid>
            </Border>

            <!-- Stream URI -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Stream URI" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox Style="{StaticResource ModernTB}" Text="{Binding StreamUri, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12" MinWidth="400" Margin="0,0,12,0" />
                        <Button Style="{StaticResource SecondaryBtn}" Content="Copy URI" Command="{Binding CopyStreamUriCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16,10" Margin="0,16,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
        </Border>
        </Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Device, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#607D8B" HorizontalAlignment="Center" />
            <TextBlock Text="No Device Connected" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,8" />
            <TextBlock Text="To use this page:" FontSize="13" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="1. Click Discover Devices to scan your network" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="2. Select a camera from the list" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="3. Enter username and password" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="4. Click Connect" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
        </StackPanel>
    </Grid>
</UserControl>
