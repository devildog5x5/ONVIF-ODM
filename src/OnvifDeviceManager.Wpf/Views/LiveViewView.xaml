<UserControl x:Class="OnvifDeviceManager.Wpf.Views.LiveViewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Wpf.Converters"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             DataContext="{Binding}"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <UserControl.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImage" />
    </UserControl.Resources>

    <Grid>
        <Grid Margin="24" Visibility="{Binding Device, Converter={StaticResource NullToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12">
                <Run Text="Live View" />
                <Run Text=" — " Foreground="{StaticResource MutedText}" />
                <Run Text="Live video (RTSP) and still snapshots for the active camera only" Foreground="{StaticResource MutedText}" FontSize="14" />
            </TextBlock>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Profile + live video + still image controls -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Stream &amp; profile (selected camera)" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Profile:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="0,0,8,0" />
                            <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                      DisplayMemberPath="Name" MinWidth="200" Margin="0,0,16,0"
                                      Background="{StaticResource InputBg}" Foreground="White" BorderBrush="{StaticResource BorderClr}" />
                            <Button x:Name="StartLiveButton" Style="{StaticResource PrimaryBtn}" Content="▶ Start live video (RTSP)"
                                    Click="StartLiveButton_Click" Margin="0,0,8,0" Padding="12,8" />
                            <Button x:Name="StopLiveButton" Style="{StaticResource DangerBtn}" Content="⏹ Stop video"
                                    Click="StopLiveButton_Click" Padding="12,8" IsEnabled="False" Margin="0,0,8,0" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="Copy RTSP URI" Command="{Binding CopyStreamUriCommand}" Margin="0,0,8,0" Padding="12,8" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="Open in media app" Command="{Binding OpenRtspExternallyCommand}" Padding="12,8"
                                    ToolTip="Opens the stream URL with the OS default handler (e.g. VLC)" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Still image:" VerticalAlignment="Center" Foreground="{StaticResource MutedText}" Margin="0,0,10,0" FontSize="12" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="Snapshot" Command="{Binding RefreshSnapshotCommand}" Margin="0,0,8,0" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="Auto refresh" Command="{Binding StartAutoRefreshCommand}" Margin="0,0,8,0" />
                            <Button Style="{StaticResource DangerBtn}" Content="Stop refresh" Command="{Binding StopAutoRefreshCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Still snapshot (separate from VideoView so LibVLC host issues do not break stills) -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" MinHeight="120"
                        Visibility="{Binding ShowSnapshotAsStill, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Still snapshot" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,0,6" />
                        <Image Source="{Binding SnapshotBytes, Converter={StaticResource BytesToImage}}"
                               Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="400" />
                    </StackPanel>
                </Border>

                <!-- Live Video (RTSP) -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <Grid Background="Black" MinHeight="280">
                        <vlc:VideoView x:Name="VideoView" Background="Black" Panel.ZIndex="0"
                                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        <TextBlock x:Name="VideoPlaceholder" Text="LIVE VIDEO — Choose profile above, then Start live video (RTSP)&#x0a;PTZ (below) works while the stream plays"
                                   Foreground="{StaticResource MutedText}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Panel.ZIndex="2"
                                   Visibility="{Binding ShowVideoPlaceholder, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>

                <!-- PTZ: position indicator + controls (same profile as stream) -->
                <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,12"
                        Visibility="{Binding ShowPtzPanel, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="PTZ — where the camera is pointing + controls"
                                   FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,10" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Position map (normalized pan/tilt from ONVIF GetStatus) -->
                            <StackPanel Grid.Column="0" Margin="0,0,20,0" MinWidth="200">
                                <TextBlock Text="Pan / tilt (center = neutral)" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,0,6" />
                                <Border BorderBrush="#3d4450" BorderThickness="1" Width="108" Height="108" CornerRadius="4"
                                        Background="#0d1117" HorizontalAlignment="Left" Padding="4">
                                    <Grid Width="100" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Line X1="50" Y1="0" X2="50" Y2="100" Stroke="#4a5568" StrokeThickness="1" />
                                        <Line X1="0" Y1="50" X2="100" Y2="50" Stroke="#4a5568" StrokeThickness="1" />
                                        <Ellipse Width="12" Height="12" Fill="#00D4AA" Stroke="#1A1A2E" StrokeThickness="1"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <TranslateTransform X="{Binding PtzIndicatorOffsetX}" Y="{Binding PtzIndicatorOffsetY}" />
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding PtzPositionText}" TextWrapping="Wrap" MaxWidth="220" FontSize="11"
                                           Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                                <Button Style="{StaticResource SecondaryBtn}" Content="Refresh position" Margin="0,8,0,0" Padding="10,6" HorizontalAlignment="Left"
                                        Command="{Binding RefreshPtzPositionCommand}" />
                                <TextBlock Text="Updates after each move and about every 1.6s while this page is open." FontSize="10"
                                           Foreground="{StaticResource MutedText}" TextWrapping="Wrap" MaxWidth="220" Margin="0,6,0,0" />
                            </StackPanel>
                            <Grid Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Row="0" Grid.Column="1" Content="▲" Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding MoveUpCommand}" Width="36" Height="36" FontSize="14" Margin="2" />
                                <Button Grid.Row="1" Grid.Column="0" Content="◀" Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding MoveLeftCommand}" Width="36" Height="36" FontSize="14" Margin="2" />
                                <Button Grid.Row="1" Grid.Column="1" Content="■" Style="{StaticResource DangerBtn}"
                                        Command="{Binding StopCommand}" Width="36" Height="36" FontSize="12" Margin="2" />
                                <Button Grid.Row="1" Grid.Column="2" Content="▶" Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding MoveRightCommand}" Width="36" Height="36" FontSize="14" Margin="2" />
                                <Button Grid.Row="2" Grid.Column="1" Content="▼" Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding MoveDownCommand}" Width="36" Height="36" FontSize="14" Margin="2" />
                            </Grid>
                            <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Top" Margin="12,0,0,0">
                                <Button Content="Zoom +" Style="{StaticResource SecondaryBtn}" Command="{Binding ZoomInCommand}" Margin="0,0,0,6" Width="72" Height="32" />
                                <Button Content="Zoom −" Style="{StaticResource SecondaryBtn}" Command="{Binding ZoomOutCommand}" Margin="0,0,0,6" Width="72" Height="32" />
                                <Button Content="Home" Style="{StaticResource PrimaryBtn}" Command="{Binding HomeCommand}" Width="72" Height="32" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Stream URI (read-only) -->
                <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Current stream URI" FontWeight="SemiBold" Foreground="{StaticResource MutedText}" Margin="0,0,0,6" />
                        <TextBox x:Name="StreamUriBox" Style="{StaticResource ModernTB}"
                                 Text="{Binding StreamUri, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="{StaticResource MonoFont}" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Event Simulator (row 1: directly under stream card so it's visible without scrolling past video) -->
                <Border Grid.Row="1" Background="#120a0a" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                        BorderBrush="#3d1a1a" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Gunshot / alarm simulator (PTZ response)" FontWeight="SemiBold" Foreground="{StaticResource Danger}" />
                                <TextBlock Text="Choose event type (e.g. Gunshot Detection), target preset or pan/tilt, then SIMULATE." FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Top" Text="{Binding LastSimulatedEvent}" Foreground="{StaticResource MutedText}" FontSize="11" MaxWidth="220" TextWrapping="Wrap" TextAlignment="Right" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Event Type" FontSize="10" Foreground="{StaticResource MutedText}" Margin="0,0,0,4" />
                                <ComboBox x:Name="EventTypeCombo" MinWidth="140" Padding="6,4"
                                          SelectionChanged="EventTypeCombo_SelectionChanged"
                                          Background="{StaticResource InputBg}" Foreground="White" BorderBrush="{StaticResource BorderClr}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Target" FontSize="10" Foreground="{StaticResource MutedText}" Margin="0,0,0,4" />
                                <StackPanel>
                                    <RadioButton x:Name="PresetRadio" Content="Preset" IsChecked="True"
                                                 Checked="EventTargetRadio_Changed" Foreground="{StaticResource SecondaryText}" />
                                    <RadioButton x:Name="CoordsRadio" Content="Coords" Margin="0,4,0,0"
                                                 Checked="EventTargetRadio_Changed" Foreground="{StaticResource SecondaryText}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel x:Name="PresetPanel" Grid.Column="4">
                                <TextBlock Text="Preset #" FontSize="10" Foreground="{StaticResource MutedText}" Margin="0,0,0,4" />
                                <ComboBox x:Name="PresetCombo" Width="60" Padding="6,4"
                                          SelectionChanged="PresetCombo_SelectionChanged"
                                          Background="{StaticResource InputBg}" Foreground="White" BorderBrush="{StaticResource BorderClr}" />
                            </StackPanel>
                            <StackPanel x:Name="CoordsPanel" Grid.Column="4" Visibility="Collapsed">
                                <TextBlock Text="Pan / Tilt" FontSize="10" Foreground="{StaticResource MutedText}" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="EventPanBox" Style="{StaticResource ModernTB}"
                                             Text="{Binding EventTargetPanString, UpdateSourceTrigger=PropertyChanged}" Width="50" Padding="6,4" FontSize="11" />
                                    <TextBlock Text=" / " Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox x:Name="EventTiltBox" Style="{StaticResource ModernTB}"
                                             Text="{Binding EventTargetTiltString, UpdateSourceTrigger=PropertyChanged}" Width="50" Padding="6,4" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="6" Content="⚡ SIMULATE" Style="{StaticResource DangerBtn}"
                                    Command="{Binding SimulateEventCommand}" Padding="14,8" VerticalAlignment="Bottom" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            </ScrollViewer>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16,10" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
            </Border>
        </Grid>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Device, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#607D8B" HorizontalAlignment="Center" />
            <TextBlock Text="No Device Connected" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,8" />
            <TextBlock Text="To use this page:" FontSize="13" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="1. Go to Discovery and scan for devices" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="2. Select a camera and click Connect" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="3. Return here for live video, PTZ, and the gunshot / ONVIF event simulator" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
        </StackPanel>
    </Grid>
</UserControl>
