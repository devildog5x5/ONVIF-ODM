<UserControl x:Class="OnvifDeviceManager.Wpf.Views.DiscoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Wpf.Converters"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:DeviceSessionHighlightConverter x:Key="DeviceSessionHighlight" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Device Discovery" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Scan the network, select a camera, enter credentials, and click Connect." 
                       Foreground="{StaticResource SecondaryText}" FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Left: Device List -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Step 1: Discover -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource Accent}" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                            <TextBlock Text="1" Foreground="#1A1A2E" FontWeight="Bold" FontSize="13" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Discover cameras on your network" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryBtn}" Content="Discover" Command="{Binding DiscoverCommand}" Margin="0,0,8,0" Padding="16,8" />
                        <Button Style="{StaticResource DangerBtn}" Content="Stop" Command="{Binding StopDiscoveryCommand}" Margin="0,0,16,0" Padding="16,8" />
                        <TextBlock Text="Timeout:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="0,0,6,0" FontSize="12" />
                        <TextBox Style="{StaticResource ModernTB}" Text="{Binding DiscoveryTimeout, UpdateSourceTrigger=PropertyChanged}" Width="50" Padding="8,6" />
                        <TextBlock Text="sec" VerticalAlignment="Center" Foreground="{StaticResource MutedText}" Margin="6,0,0,0" FontSize="12" />
                    </StackPanel>

                    <!-- Step 2: Select a device -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="{StaticResource Accent}" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                                <TextBlock Text="2" Foreground="#1A1A2E" FontWeight="Bold" FontSize="13" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Click a device to select it" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Devices.Count, StringFormat='  ({0} found)'}" 
                                       Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>

                        <ListBox Grid.Row="1" 
                                 ItemsSource="{Binding Devices}" 
                                 SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                 Style="{StaticResource ModernLB}" 
                                 ItemContainerStyle="{StaticResource ModernLBI}"
                                 MinHeight="150"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" CornerRadius="6">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource DeviceSessionHighlight}">
                                                <Binding />
                                                <Binding Path="DataContext.ActiveSessionAddress" RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                            </MultiBinding>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="12" Height="12" Margin="0,0,12,0" VerticalAlignment="Center"
                                                     Fill="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Manufacturer}" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                                                    <TextBlock Text=" - " Foreground="{StaticResource MutedText}" FontSize="12" />
                                                    <TextBlock Text="{Binding Model}" Foreground="{StaticResource MutedText}" FontSize="12" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Address}" Foreground="{StaticResource MutedText}" FontSize="11" 
                                                           FontFamily="{StaticResource MonoFont}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="{StaticResource MutedText}" 
                                                       FontSize="11" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Manual Add -->
                        <Border Grid.Row="2" Background="#0D1B2A" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Add manually:" Foreground="{StaticResource MutedText}" FontSize="12" 
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Grid.Column="1" Style="{StaticResource ModernTB}" 
                                         Text="{Binding ManualAddress, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="8,6" Margin="0,0,8,0" />
                                <Button Grid.Column="2" Style="{StaticResource SecondaryBtn}" Content="Add" 
                                        Command="{Binding AddManualCommand}" Padding="12,6" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right: Credentials & Connect -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Step 3: Enter credentials -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource Accent}" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                            <TextBlock Text="3" Foreground="#1A1A2E" FontWeight="Bold" FontSize="13" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Enter credentials &amp; connect" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Selected device indicator -->
                    <Border Background="#0D1B2A" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Selected Device:" Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"
                                       Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVis}}">
                                <TextBlock.Text>
                                    <Binding Path="SelectedDevice.DisplayName" />
                                </TextBlock.Text>
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#00D4AA" />
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="None — click a device in the list" FontSize="13" 
                                       Foreground="#E94560" FontWeight="SemiBold" Margin="0,4,0,0"
                                       Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVis}, ConverterParameter=Invert}" />
                        </StackPanel>
                    </Border>

                    <!-- Credential source -->
                    <TextBlock Text="{Binding CredentialSource}" FontSize="11" Foreground="{StaticResource Accent}" 
                               Margin="0,0,0,8" />

                    <TextBlock Text="Username" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTB}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                    <TextBlock Text="Password" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTB}" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                    <CheckBox IsChecked="{Binding SaveCredentials}" Margin="0,0,0,14">
                        <TextBlock Text="Save credentials" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                    </CheckBox>

                    <!-- Step 4: Connect -->
                    <Button Style="{StaticResource PrimaryBtn}" Content="Connect" 
                            Command="{Binding ConnectCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                            FontSize="15" Padding="20,12" />

                    <Button Style="{StaticResource DangerBtn}" Content="Disconnect (end session)" 
                            Command="{Binding DisconnectCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                            Padding="14,10" FontSize="13"
                            IsEnabled="{Binding SelectedDevice.IsAuthenticated}" />

                    <Button Style="{StaticResource SecondaryBtn}" Content="Connect All (saved credentials)" 
                            Command="{Binding ConnectAllCommand}" HorizontalAlignment="Stretch"
                            Padding="14,8" FontSize="12" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0D1B2A" CornerRadius="8" Padding="16,10" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource SecondaryText}" FontSize="12" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
