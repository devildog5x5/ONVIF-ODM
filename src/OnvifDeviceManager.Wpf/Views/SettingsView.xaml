<UserControl x:Class="OnvifDeviceManager.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             xmlns:models="clr-namespace:OnvifDeviceManager.Models;assembly=OnvifDeviceManager.Core"
             DataContext="{Binding}"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Timeouts Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Timeouts" FontWeight="SemiBold" Margin="0,0,0,16" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Discovery Timeout (sec):" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                            <TextBox Grid.Column="1" Style="{StaticResource ModernTB}" Text="{Binding DiscoveryTimeout, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Connection Timeout (sec):" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                            <TextBox Grid.Column="1" Style="{StaticResource ModernTB}" Text="{Binding ConnectionTimeout, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Snapshot Refresh Rate (ms):" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                            <TextBox Grid.Column="1" Style="{StaticResource ModernTB}" Text="{Binding SnapshotRefreshRate, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Options Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Options" FontWeight="SemiBold" Margin="0,0,0,16" />
                        <CheckBox Content="Auto discover on startup" IsChecked="{Binding AutoDiscoverOnStartup}"
                                  Foreground="{StaticResource SecondaryText}" Margin="0,0,0,12" />
                        <CheckBox Content="Remember credentials" IsChecked="{Binding RememberCredentials}"
                                  Foreground="{StaticResource SecondaryText}" Margin="0,0,0,16" />
                        <TextBlock Text="Default Username" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource ModernTB}" Text="{Binding DefaultUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                        <TextBlock Text="Default Password" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource ModernTB}" Text="{Binding DefaultPassword, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!-- Downloads & builds -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Downloads &amp; builds" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Quick links open in your browser. Refresh loads file names from the latest GitHub Release." Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Style="{StaticResource SecondaryBtn}" Content="README — direct links" Padding="10,6" Margin="0,0,8,0" Command="{Binding OpenReadmeDownloadsCommand}" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="Latest release" Padding="10,6" Margin="0,0,8,0" Command="{Binding OpenReleasesLatestCommand}" />
                            <Button Style="{StaticResource SecondaryBtn}" Content="CI builds (main)" Padding="10,6" Command="{Binding OpenCiWorkflowCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Release tag:" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding LatestReleaseTag}" Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Style="{StaticResource PrimaryBtn}" Content="Refresh file list" Padding="10,6" Command="{Binding RefreshLatestDownloadsCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DownloadsSectionStatus}" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding LatestReleaseAssets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ReleaseDownloadItem}">
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryBtn}" Content="Open" Padding="8,4" Margin="8,0,0,0"
                                                Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Url}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- About Card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="About" FontWeight="SemiBold" Margin="0,0,0,16" />
                        <TextBlock Text="ONVIF Device Manager" FontSize="16" Margin="0,0,0,8" />
                        <TextBlock Text="Version 1.0.0" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                        <TextBlock Text=".NET 8.0 / WPF" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                        <TextBlock Text="Author: Robert Foster" Foreground="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                    <Button Style="{StaticResource PrimaryBtn}" Content="Save" Command="{Binding SaveCommand}" Margin="0,0,12,0" />
                    <Button Style="{StaticResource SecondaryBtn}" Content="Reset" Command="{Binding ResetCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16,10" Margin="0,16,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
