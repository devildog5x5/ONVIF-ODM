<UserControl x:Class="OnvifDeviceManager.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             DataContext="{Binding}"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}">

    <Grid>
        <Grid Margin="24" Visibility="{Binding Device, Converter={StaticResource NullToVis}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="User Management" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Users DataGrid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          RowBackground="{StaticResource InputBg}" AlternatingRowBackground="#0F1520"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderClr}"
                          HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource SecondaryBg}" />
                            <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderClr}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                        <DataGridTextColumn Header="User Level" Binding="{Binding UserLevel}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Create User Form -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Create User" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <TextBlock Text="Username" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTB}" Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="Password" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTB}" Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="User Level" Foreground="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding UserLevels}" SelectedItem="{Binding SelectedUserLevel}"
                              Background="{StaticResource InputBg}" Foreground="White" BorderBrush="{StaticResource BorderClr}"
                              Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryBtn}" Content="Create" Command="{Binding CreateUserCommand}" Margin="0,0,8,0" />
                        <Button Style="{StaticResource DangerBtn}" Content="Delete" Command="{Binding DeleteUserCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16,10" Margin="0,16,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
        </Border>
        </Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Device, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#607D8B" HorizontalAlignment="Center" />
            <TextBlock Text="No Device Connected" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,8" />
            <TextBlock Text="To use this page:" FontSize="13" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="1. Click Discover Devices to scan your network" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="2. Select a camera from the list" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="3. Enter username and password" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
            <TextBlock Text="4. Click Connect" FontSize="13" Foreground="#B0BEC5" Margin="0,2" />
        </StackPanel>
    </Grid>
</UserControl>
