<UserControl x:Class="OnvifDeviceManager.Wpf.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels;assembly=OnvifDeviceManager.Core"
             DataContext="{Binding}"
             Background="{StaticResource PrimaryBg}"
             Foreground="{StaticResource PrimaryText}"
             FontFamily="{StaticResource MainFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Media Profiles" FontSize="24" FontWeight="SemiBold" />
            <Button Style="{StaticResource SecondaryBtn}" Content="Refresh" Command="{Binding RefreshCommand}" Margin="24,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Profile List -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Profiles" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                             DisplayMemberPath="Name" Style="{StaticResource ModernLB}" ItemContainerStyle="{StaticResource ModernLBI}" />
                </Grid>
            </Border>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <TextBlock Text="Select a profile" Foreground="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                        <StackPanel>
                            <TextBlock Text="Profile Details" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Name:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.Name}" FontFamily="{StaticResource MonoFont}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Token:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.Token}" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PTZ Enabled:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.IsPtzEnabled}" />
                        </Grid>

                        <TextBlock Text="Video Encoder" FontWeight="SemiBold" Margin="0,20,0,12" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Encoding:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.Encoding}" FontFamily="{StaticResource MonoFont}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Resolution:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.Resolution}" FontFamily="{StaticResource MonoFont}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Frame Rate:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.FrameRate, StringFormat='{}{0} fps'}" FontFamily="{StaticResource MonoFont}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bit Rate:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.BitRate, StringFormat='{}{0} kbps'}" FontFamily="{StaticResource MonoFont}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Quality:" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.Quality}" FontFamily="{StaticResource MonoFont}" />
                        </Grid>

                        <TextBlock Text="Stream URI" FontWeight="SemiBold" Margin="0,20,0,12" />
                        <TextBlock Text="{Binding SelectedProfile.StreamUri}" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryText}" Margin="0,0,0,16" />

                        <TextBlock Text="Snapshot URI" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding SelectedProfile.SnapshotUri}" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryText}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16,10" Margin="0,16,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
