<Window x:Class="OnvifDeviceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OnvifDeviceManager.ViewModels"
        xmlns:views="clr-namespace:OnvifDeviceManager.Views"
        xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
        Title="ONVIF Device Manager"
        Width="1400" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />

        <DataTemplate DataType="{x:Type vm:DiscoveryViewModel}">
            <views:DiscoveryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeviceInfoViewModel}">
            <views:DeviceInfoView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveViewViewModel}">
            <views:LiveViewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PtzViewModel}">
            <views:PtzView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfilesViewModel}">
            <views:ProfilesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkViewModel}">
            <views:NetworkView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventsViewModel}">
            <views:EventsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBackgroundBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <StackPanel>
                        <TextBlock Text="ONVIF Device Manager" Style="{StaticResource SubHeaderText}" />
                        <TextBlock Text="Discover and manage ONVIF IP cameras" Style="{StaticResource CaptionText}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedDevice.DisplayName, FallbackValue='No Device Selected'}" 
                               Style="{StaticResource BodyText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                             Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVisibility}}">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{StaticResource AccentColor}" />
                        </Ellipse.Fill>
                    </Ellipse>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8">
                        <StackPanel>
                            <!-- Discovery Section -->
                            <TextBlock Text="DISCOVERY" Style="{StaticResource CaptionText}" 
                                       Margin="16,12,0,4" FontWeight="Bold" />

                            <RadioButton Style="{StaticResource NavButton}" IsChecked="True"
                                         Command="{Binding NavigateCommand}" CommandParameter="Discovery">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Discover Devices" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <!-- Device Section -->
                            <TextBlock Text="DEVICE" Style="{StaticResource CaptionText}" 
                                       Margin="16,20,0,4" FontWeight="Bold" />

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="DeviceInfo"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Device Info" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="LiveView"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Live View" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="PTZ"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="PTZ Control" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="Profiles"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Media Profiles" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <!-- Management Section -->
                            <TextBlock Text="MANAGEMENT" Style="{StaticResource CaptionText}" 
                                       Margin="16,20,0,4" FontWeight="Bold" />

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="Network"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Network" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="Users"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Users" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="Events"
                                         IsEnabled="{Binding IsDeviceConnected}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Events" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <!-- Settings Section -->
                            <TextBlock Text="APPLICATION" Style="{StaticResource CaptionText}" 
                                       Margin="16,20,0,4" FontWeight="Bold" />

                            <RadioButton Style="{StaticResource NavButton}"
                                         Command="{Binding NavigateCommand}" CommandParameter="Settings">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Settings" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Version Info -->
                    <Border Grid.Row="1" Padding="16,8" 
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <TextBlock Text="v1.0.0" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0" />
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SecondaryBackgroundBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />

                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                            <Setter Property="Text" Value="{Binding Devices.Count, StringFormat='{}{0} device(s)'}" />
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Column="2" Style="{StaticResource CaptionText}" VerticalAlignment="Center"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='HH:mm:ss'}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib" />
            </Grid>
        </Border>
    </Grid>
</Window>
