<UserControl x:Class="OnvifDeviceManager.Views.PtzView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <TextBlock Text="PTZ Control" Style="{StaticResource HeaderText}" />
            <TextBlock Text="Control pan, tilt, and zoom for PTZ-enabled cameras" 
                       Style="{StaticResource BodyText}" Margin="0,4,0,24" />

            <!-- Profile Selection -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PTZ Profile:" Style="{StaticResource BodyText}" 
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ComboBox Width="250" ItemsSource="{Binding PtzProfiles}" 
                              SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBox}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- PTZ Directional Pad -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Direction Controls" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />

                        <Grid HorizontalAlignment="Center" Width="200" Height="200">
                            <!-- Up -->
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding MoveUpCommand}"
                                    Width="56" Height="56" Padding="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Top">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
                            </Button>

                            <!-- Down -->
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding MoveDownCommand}"
                                    Width="56" Height="56" Padding="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
                            </Button>

                            <!-- Left -->
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding MoveLeftCommand}"
                                    Width="56" Height="56" Padding="0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Button>

                            <!-- Right -->
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding MoveRightCommand}"
                                    Width="56" Height="56" Padding="0"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Button>

                            <!-- Stop (Center) -->
                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding StopCommand}"
                                    Width="48" Height="48" Padding="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                            </Button>
                        </Grid>

                        <!-- Zoom Controls -->
                        <TextBlock Text="Zoom" Style="{StaticResource CaptionText}" Margin="0,20,0,8" 
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding ZoomOutCommand}"
                                    Width="48" Height="48" Padding="0" Margin="0,0,12,0">
                                <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding ZoomInCommand}"
                                    Width="48" Height="48" Padding="0">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                            </Button>
                        </StackPanel>

                        <!-- Home Button -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding HomeCommand}"
                                    Content="Go Home" Padding="16,8" Margin="0,0,8,0" />
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding SetHomeCommand}"
                                    Content="Set Home" Padding="16,8" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Speed & Presets -->
                <StackPanel Grid.Column="2">
                    <!-- Speed Controls -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Speed Settings" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />

                            <TextBlock Text="Pan Speed" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="0.1" Maximum="1.0" 
                                        Value="{Binding PanSpeed}" TickFrequency="0.1"
                                        Style="{StaticResource ModernSlider}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding PanSpeed, StringFormat='{}{0:F1}'}" 
                                           Style="{StaticResource BodyText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="Tilt Speed" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="0.1" Maximum="1.0" 
                                        Value="{Binding TiltSpeed}" TickFrequency="0.1"
                                        Style="{StaticResource ModernSlider}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding TiltSpeed, StringFormat='{}{0:F1}'}" 
                                           Style="{StaticResource BodyText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="Zoom Speed" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="0.1" Maximum="1.0" 
                                        Value="{Binding ZoomSpeed}" TickFrequency="0.1"
                                        Style="{StaticResource ModernSlider}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding ZoomSpeed, StringFormat='{}{0:F1}'}" 
                                           Style="{StaticResource BodyText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Presets -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Presets" Style="{StaticResource SubHeaderText}" />
                                <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                                        Command="{Binding RefreshPresetsCommand}" ToolTip="Refresh Presets">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                                </Button>
                            </Grid>

                            <ListBox Style="{StaticResource ModernListBox}" 
                                     ItemContainerStyle="{StaticResource ModernListBoxItem}"
                                     ItemsSource="{Binding Presets}" 
                                     SelectedItem="{Binding SelectedPreset}"
                                     MaxHeight="150">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButton}" Content="Go To"
                                        Command="{Binding GotoPresetCommand}" Padding="12,6" Margin="0,0,8,0" />
                                <Button Style="{StaticResource DangerButton}" Content="Delete"
                                        Command="{Binding DeletePresetCommand}" Padding="12,6" />
                            </StackPanel>

                            <Separator Style="{StaticResource ModernSeparator}" Margin="0,12" />

                            <TextBlock Text="Save New Preset" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource ModernTextBox}" 
                                         Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" 
                                        Content="Save" Command="{Binding SavePresetCommand}" Padding="12,6" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Position Status -->
            <Border Margin="0,16,0,0" Padding="12,8" 
                    Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
                <Grid>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
                    <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                            Command="{Binding GetStatusCommand}" ToolTip="Refresh Position" Width="24" Height="24">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                    </Button>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
