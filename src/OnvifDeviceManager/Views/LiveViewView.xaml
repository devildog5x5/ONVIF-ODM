<UserControl x:Class="OnvifDeviceManager.Views.LiveViewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Live View" Style="{StaticResource HeaderText}" />
            <TextBlock Text="View live snapshots from the camera" 
                       Style="{StaticResource BodyText}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Profile:" Style="{StaticResource BodyText}" 
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Width="200" ItemsSource="{Binding Profiles}" 
                              SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBox}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding RefreshSnapshotCommand}" 
                            Margin="0,0,8,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Snapshot" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding StartAutoRefreshCommand}" 
                            Margin="0,0,8,0" Padding="12,8"
                            Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Auto" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DangerButton}" Command="{Binding StopAutoRefreshCommand}" 
                            Padding="12,8"
                            Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Stop" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IconButton}" Command="{Binding CopyStreamUriCommand}" 
                            ToolTip="Copy RTSP Stream URI" Margin="8,0,0,0">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Video Area -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <!-- Snapshot Image -->
                <Image Source="{Binding SnapshotImage}" Stretch="Uniform" 
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="{Binding SnapshotImage, Converter={StaticResource NullToVis}}" />

                <!-- No Image Placeholder -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SnapshotImage, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                    <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="64" 
                               Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="No image available" Style="{StaticResource BodyText}" 
                               HorizontalAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="Click 'Snapshot' to capture a frame" Style="{StaticResource CaptionText}" 
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Loading Overlay -->
                <Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Loading..." Foreground="White" FontSize="16" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Stream Info & Status -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Padding="12,8" Background="{StaticResource CardBrush}" 
                    CornerRadius="{StaticResource MediumCornerRadius}">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
                    <TextBlock Text="{Binding StreamUri}" Style="{StaticResource CaptionText}" 
                               Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"
                               Margin="0,4,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
