<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OnvifDeviceManager.ViewModels"
             xmlns:conv="using:OnvifDeviceManager.Converters"
             x:Class="OnvifDeviceManager.Views.DiscoveryView"
             x:DataType="vm:DiscoveryViewModel">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:IntToBoolConverter x:Key="IntToBool" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <TextBlock Text="Device Discovery" Classes="header" />
            <TextBlock Text="Scan the network for ONVIF-compliant cameras and devices"
                       Classes="body" Margin="0,4,0,20" />

            <!-- Action Bar -->
            <Border Classes="card" Margin="0,0,0,16">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                    <Button Grid.Column="0" Classes="primary" Command="{Binding DiscoverCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <PathIcon Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                      Foreground="#1A1A2E" Width="14" Height="14" Margin="0,0,8,0" />
                            <TextBlock Text="Discover" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" Classes="secondary" Command="{Binding StopDiscoveryCommand}">
                        <TextBlock Text="Stop" />
                    </Button>

                    <TextBlock Grid.Column="2" Text="Scanning..." Classes="accent"
                               IsVisible="{Binding IsDiscovering}"
                               VerticalAlignment="Center" Margin="16,0" />

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <TextBlock Text="Timeout:" Classes="body" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Classes="modern" Width="60"
                                 Text="{Binding DiscoveryTimeout}" />
                        <TextBlock Text="sec" Classes="body" VerticalAlignment="Center" Margin="8,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Device List -->
            <Border Classes="card" MinHeight="300">
                <Grid RowDefinitions="Auto,*">
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Discovered Devices" Classes="subheader" />
                        <TextBlock HorizontalAlignment="Right" Classes="caption" VerticalAlignment="Center"
                                   Text="{Binding Devices.Count, StringFormat='{}{0} device(s) found'}" />
                    </Grid>

                    <ListBox Grid.Row="1" Classes="modern"
                             ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding SelectedDevice}"
                             MinHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="4">
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0"
                                             VerticalAlignment="Center"
                                             Fill="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Manufacturer}" Classes="caption" />
                                            <TextBlock Text=" - " Classes="caption" />
                                            <TextBlock Text="{Binding Model}" Classes="caption" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Address}" Classes="caption" Foreground="#607D8B" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}" Classes="caption" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsVisible="{Binding !Devices.Count}">
                        <PathIcon Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                  Foreground="#607D8B" Width="48" Height="48" HorizontalAlignment="Center" />
                        <TextBlock Text="No devices discovered yet" Classes="body" HorizontalAlignment="Center" Margin="0,12,0,0" />
                        <TextBlock Text="Click 'Discover' to scan the network" Classes="caption" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Manual Add & Connect -->
            <Grid ColumnDefinitions="*,16,*" Margin="0,16,0,0">
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Add Device Manually" Classes="subheader" Margin="0,0,0,12" />
                        <TextBlock Text="IP Address or URL" Classes="caption" Margin="0,0,0,4" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Classes="modern" Text="{Binding ManualAddress}" Margin="0,0,8,0" />
                            <Button Grid.Column="1" Classes="secondary" Content="Add" Command="{Binding AddManualCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Credentials" Classes="subheader" Margin="0,0,0,12" />
                        <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Text="Username" Classes="caption" Margin="0,0,0,4" />
                            <TextBlock Grid.Column="2" Text="Password" Classes="caption" Margin="0,0,0,4" />
                            <TextBox Grid.Row="1" Classes="modern" Text="{Binding Username}" />
                            <TextBox Grid.Row="1" Grid.Column="2" Classes="modern"
                                     Text="{Binding Password}" PasswordChar="*" />
                            <Button Grid.Row="2" Grid.ColumnSpan="3" Classes="primary"
                                    Content="Connect" Command="{Binding ConnectCommand}"
                                    HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status -->
            <Border Margin="0,12,0,0" Padding="12,8" Background="#1E2A4A" CornerRadius="8">
                <TextBlock Text="{Binding StatusText}" Classes="caption" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
