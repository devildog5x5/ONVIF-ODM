<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OnvifDeviceManager.ViewModels"
             xmlns:conv="using:OnvifDeviceManager.Converters"
             x:Class="OnvifDeviceManager.Views.DiscoveryView"
             x:DataType="vm:DiscoveryViewModel">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <TextBlock Text="Device Discovery" Classes="header" />
            <TextBlock Text="Scan the network, select a camera, enter credentials, and click Connect."
                       Classes="body" Margin="0,4,0,20" />

            <Grid ColumnDefinitions="*,16,340">
                <!-- Left: Device List -->
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <!-- Step 1 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#00D4AA" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                                <TextBlock Text="1" Foreground="#1A1A2E" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Discover cameras on your network" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                            <Button Classes="primary" Command="{Binding DiscoverCommand}" Padding="16,8">
                                <TextBlock Text="Discover" />
                            </Button>
                            <Button Classes="secondary" Command="{Binding StopDiscoveryCommand}" Padding="16,8">
                                <TextBlock Text="Stop" />
                            </Button>
                            <TextBlock Text="Scanning..." Classes="accent" IsVisible="{Binding IsDiscovering}" VerticalAlignment="Center" Margin="8,0" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="Timeout:" Classes="caption" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Classes="modern" Width="50" Text="{Binding DiscoveryTimeout}" Padding="8,4" />
                                <TextBlock Text="sec" Classes="caption" VerticalAlignment="Center" Margin="4,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 2 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#00D4AA" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                                <TextBlock Text="2" Foreground="#1A1A2E" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Click a device to select it" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Devices.Count, StringFormat='  ({0} found)'}" Classes="caption" VerticalAlignment="Center" />
                        </StackPanel>

                        <ListBox Classes="modern" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" MinHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="4">
                                        <Ellipse Grid.Column="0" Width="12" Height="12" Margin="0,0,12,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Manufacturer}" Classes="caption" />
                                                <TextBlock Text=" - " Classes="caption" />
                                                <TextBlock Text="{Binding Model}" Classes="caption" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Address}" Classes="mono" FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Status}" Classes="caption" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state -->
                        <StackPanel IsVisible="{Binding !Devices.Count}" HorizontalAlignment="Center" Margin="0,20">
                            <TextBlock Text="No devices found yet" Classes="body" HorizontalAlignment="Center" />
                            <TextBlock Text="Click Discover to scan, or add a device manually below" Classes="caption" HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- Manual Add -->
                        <Border Background="#0D1B2A" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="Add manually:" Classes="caption" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Grid.Column="1" Classes="modern" Text="{Binding ManualAddress}" Margin="0,0,8,0"
                                         Watermark="192.168.1.100" Padding="8,4" />
                                <Button Grid.Column="2" Classes="secondary" Content="Add" Command="{Binding AddManualCommand}" Padding="12,6" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Right: Credentials -->
                <Border Grid.Column="2" Classes="card">
                    <StackPanel>
                        <!-- Step 3 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#00D4AA" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                                <TextBlock Text="3" Foreground="#1A1A2E" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Enter credentials" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Selected device indicator -->
                        <Border Background="#0D1B2A" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Selected Device:" Classes="caption" />
                                <TextBlock Text="{Binding SelectedDevice.DisplayName}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#00D4AA" Margin="0,4,0,0"
                                           IsVisible="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <TextBlock Text="None — click a device in the list" FontSize="13"
                                           Foreground="#E94560" FontWeight="SemiBold" Margin="0,4,0,0"
                                           IsVisible="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNull}}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding CredentialSource}" Classes="accent" FontSize="11" Margin="0,0,0,8" />

                        <TextBlock Text="Username" Classes="caption" Margin="0,0,0,4" />
                        <TextBox Classes="modern" Text="{Binding Username}" Margin="0,0,0,10" />

                        <TextBlock Text="Password" Classes="caption" Margin="0,0,0,4" />
                        <TextBox Classes="modern" Text="{Binding Password}" PasswordChar="*" Margin="0,0,0,10" />

                        <CheckBox IsChecked="{Binding SaveCredentials}" Margin="0,0,0,14">
                            <TextBlock Text="Save credentials" Foreground="#B0BEC5" FontSize="12" />
                        </CheckBox>

                        <Button Classes="primary" Content="Connect" Command="{Binding ConnectCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8" FontSize="15" Padding="20,12" />

                        <Button Classes="secondary" Content="Connect All (saved credentials)"
                                Command="{Binding ConnectAllCommand}" HorizontalAlignment="Stretch" Padding="14,8" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status -->
            <Border Margin="0,12,0,0" Padding="12,8" Background="#0D1B2A" CornerRadius="8">
                <TextBlock Text="{Binding StatusText}" Classes="body" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
