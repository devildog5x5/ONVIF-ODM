<UserControl x:Class="OnvifDeviceManager.Views.DiscoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StatusToColorConverter x:Key="StatusToColor" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Device Discovery" Style="{StaticResource HeaderText}" />
            <TextBlock Text="Scan the network for ONVIF-compliant cameras and devices" 
                       Style="{StaticResource BodyText}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Bar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" 
                        Command="{Binding DiscoverCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Discover" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" 
                        Command="{Binding StopDiscoveryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Stop" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Loading Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center"
                            Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Scanning..." Style="{StaticResource AccentText}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock Text="Timeout:" Style="{StaticResource BodyText}" 
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Style="{StaticResource ModernTextBox}" Width="60" 
                             Text="{Binding DiscoveryTimeout, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="sec" Style="{StaticResource BodyText}" 
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Device List -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Discovered Devices" Style="{StaticResource SubHeaderText}" />
                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource CaptionText}" 
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="Devices.Count" StringFormat="{}{0} device(s) found" />
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <ListBox Grid.Row="1" 
                         Style="{StaticResource ModernListBox}"
                         ItemContainerStyle="{StaticResource ModernListBoxItem}"
                         ItemsSource="{Binding Devices}" 
                         SelectedItem="{Binding SelectedDevice}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Status Indicator -->
                                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                    </Ellipse.Fill>
                                </Ellipse>

                                <!-- Device Info -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" 
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource CaptionText}" />
                                        <TextBlock Text=" - " Style="{StaticResource CaptionText}" 
                                                   Visibility="{Binding Manufacturer, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding Model}" Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Address}" Style="{StaticResource CaptionText}" 
                                               Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" />
                                </StackPanel>

                                <!-- Status Text -->
                                <TextBlock Grid.Column="2" Text="{Binding Status}" 
                                           Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty State -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Devices.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                               Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="No devices discovered yet" Style="{StaticResource BodyText}" 
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                    <TextBlock Text="Click 'Discover' to scan the network" Style="{StaticResource CaptionText}" 
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Manual Add & Connect -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Manual Add -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Add Device Manually" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />
                    <TextBlock Text="IP Address or URL" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding ManualAddress, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" 
                                Content="Add" Command="{Binding AddManualCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Connect -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Credentials" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Username" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                        <TextBlock Grid.Column="2" Text="Password" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                        <TextBox Grid.Row="1" Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource PrimaryButton}" 
                                Content="Connect" Command="{Binding ConnectCommand}" 
                                HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="4" Margin="0,12,0,0" Padding="12,8" 
                Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
        </Border>
    </Grid>
</UserControl>
