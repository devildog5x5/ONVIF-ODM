<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OnvifDeviceManager.ViewModels"
             x:Class="OnvifDeviceManager.Views.LiveViewView"
             x:DataType="vm:LiveViewViewModel">

    <Grid Margin="24" RowDefinitions="Auto,Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Live View" Classes="header" />
            <TextBlock Text="View live snapshots from the camera" Classes="body" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Profile:" Classes="body" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Classes="modern" Width="200" ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Classes="primary" Command="{Binding RefreshSnapshotCommand}" Padding="12,8">
                        <TextBlock Text="Snapshot" />
                    </Button>
                    <Button Classes="secondary" Command="{Binding StartAutoRefreshCommand}" Padding="12,8"
                            IsVisible="{Binding !IsRefreshing}">
                        <TextBlock Text="Auto Refresh" />
                    </Button>
                    <Button Classes="danger" Command="{Binding StopAutoRefreshCommand}" Padding="12,8"
                            IsVisible="{Binding IsRefreshing}">
                        <TextBlock Text="Stop" />
                    </Button>
                    <Button Classes="icon" Command="{Binding CopyStreamUriCommand}" ToolTip.Tip="Copy RTSP URI">
                        <PathIcon Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                                  Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Video Area -->
        <Border Grid.Row="2" Classes="card">
            <Grid>
                <Image Source="{Binding SnapshotImage}" Stretch="Uniform"
                       IsVisible="{Binding SnapshotImage, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsVisible="{Binding SnapshotImage, Converter={x:Static ObjectConverters.IsNull}}">
                    <PathIcon Data="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"
                              Foreground="#607D8B" Width="64" Height="64" HorizontalAlignment="Center" />
                    <TextBlock Text="No image available" Classes="body" HorizontalAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="Click 'Snapshot' to capture a frame" Classes="caption" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <Border Background="#80000000" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Loading..." Foreground="White" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8" Background="#1E2A4A" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="{Binding StatusText}" Classes="caption" />
                <TextBlock Text="{Binding StreamUri}" Classes="mono" Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
