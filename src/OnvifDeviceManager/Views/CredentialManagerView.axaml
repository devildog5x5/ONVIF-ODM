<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OnvifDeviceManager.ViewModels"
             x:Class="OnvifDeviceManager.Views.CredentialManagerView"
             x:DataType="vm:CredentialManagerViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Credential Manager" Classes="header" />
            <TextBlock Text="Manage per-device and group credentials for ONVIF cameras" Classes="body" Margin="0,4,0,24" />

            <Grid ColumnDefinitions="*,16,*">
                <!-- Device Credentials -->
                <StackPanel Grid.Column="0" Spacing="16">
                    <Border Classes="card">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Device Credentials" Classes="subheader" />
                                <TextBlock Text="{Binding Credentials.Count, StringFormat='{}{0} saved'}" 
                                           Classes="caption" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>

                            <ListBox Classes="modern" ItemsSource="{Binding Credentials}" SelectedItem="{Binding SelectedCredential}" MaxHeight="200">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DeviceAddress}" FontWeight="SemiBold" Foreground="White" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Username}" Classes="caption" Foreground="#00D4AA" />
                                                    <TextBlock Text="{Binding DeviceName, StringFormat=' ({0})'}" Classes="caption" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding LastUsed, StringFormat='yyyy-MM-dd'}" Classes="caption" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Classes="danger" Content="Delete Selected" Command="{Binding DeleteDeviceCredentialCommand}" 
                                    Margin="0,8,0,0" Padding="12,6" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Add/Edit Device Credential -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Add / Update Device Credential" Classes="subheader" Margin="0,0,0,12" />
                            <TextBlock Text="Device Address (IP or hostname)" Classes="caption" Margin="0,0,0,4" />
                            <TextBox Classes="modern" Text="{Binding NewDeviceAddress}" Margin="0,0,0,8" />
                            <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                                <TextBlock Text="Username" Classes="caption" Margin="0,0,0,4" />
                                <TextBlock Grid.Column="2" Text="Password" Classes="caption" Margin="0,0,0,4" />
                                <TextBox Grid.Row="1" Classes="modern" Text="{Binding NewDeviceUsername}" />
                                <TextBox Grid.Row="1" Grid.Column="2" Classes="modern" Text="{Binding NewDevicePassword}" PasswordChar="*" />
                            </Grid>
                            <Button Classes="primary" Content="Save Credential" Command="{Binding SaveDeviceCredentialCommand}" Padding="12,8" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Device Groups -->
                <StackPanel Grid.Column="2" Spacing="16">
                    <Border Classes="card">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Device Groups" Classes="subheader" />
                                <TextBlock Text="{Binding Groups.Count, StringFormat='{}{0} group(s)'}" 
                                           Classes="caption" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>

                            <ListBox Classes="modern" ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" MaxHeight="150">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Username}" Classes="caption" Foreground="#00D4AA" />
                                                    <TextBlock Text="{Binding DeviceAddresses.Count, StringFormat=' • {0} device(s)'}" Classes="caption" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Group devices list -->
                            <Border Background="#0D1B2A" CornerRadius="8" Padding="8" Margin="0,8,0,0"
                                    IsVisible="{Binding SelectedGroup, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <StackPanel>
                                    <TextBlock Text="Devices in this group:" Classes="caption" FontWeight="Bold" Margin="0,0,0,4" />
                                    <ItemsControl ItemsSource="{Binding SelectedGroupDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                    <TextBlock Text="{Binding}" Classes="mono" VerticalAlignment="Center" />
                                                    <Button Grid.Column="1" Classes="danger" Content="X" Padding="6,2"
                                                            Command="{Binding $parent[UserControl].((vm:CredentialManagerViewModel)DataContext).RemoveDeviceFromGroupCommand}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                        <TextBox Classes="modern" Text="{Binding AddToGroupAddress}" Margin="0,0,8,0" Watermark="Add device address..." />
                                        <Button Grid.Column="1" Classes="primary" Content="Add" Command="{Binding AddDeviceToGroupCommand}" Padding="12,6" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Classes="secondary" Content="Update Group" Command="{Binding UpdateGroupCommand}" Padding="12,6" />
                                <Button Classes="danger" Content="Delete Group" Command="{Binding DeleteGroupCommand}" Padding="12,6" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Create Group -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Create New Group" Classes="subheader" Margin="0,0,0,12" />
                            <TextBlock Text="Group Name" Classes="caption" Margin="0,0,0,4" />
                            <TextBox Classes="modern" Text="{Binding NewGroupName}" Margin="0,0,0,8" />
                            <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                                <TextBlock Text="Shared Username" Classes="caption" Margin="0,0,0,4" />
                                <TextBlock Grid.Column="2" Text="Shared Password" Classes="caption" Margin="0,0,0,4" />
                                <TextBox Grid.Row="1" Classes="modern" Text="{Binding NewGroupUsername}" />
                                <TextBox Grid.Row="1" Grid.Column="2" Classes="modern" Text="{Binding NewGroupPassword}" PasswordChar="*" />
                            </Grid>
                            <Button Classes="primary" Content="Create Group" Command="{Binding CreateGroupCommand}" Padding="12,8" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Margin="0,16,0,0" Padding="12,8" Background="#1E2A4A" CornerRadius="8">
                <TextBlock Text="{Binding StatusText}" Classes="caption" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
