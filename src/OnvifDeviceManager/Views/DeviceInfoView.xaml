<UserControl x:Class="OnvifDeviceManager.Views.DeviceInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Margin="24">
            <!-- Header -->
            <TextBlock Text="Device Information" Style="{StaticResource HeaderText}" />
            <TextBlock Text="View detailed information about the connected device" 
                       Style="{StaticResource BodyText}" Margin="0,4,0,24" />

            <!-- Device Details Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Device Details" Style="{StaticResource SubHeaderText}" />
                        <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"
                                Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MANUFACTURER" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.Manufacturer, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />

                            <TextBlock Text="MODEL" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.Model, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />

                            <TextBlock Text="FIRMWARE VERSION" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.FirmwareVersion, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />

                            <TextBlock Text="SERIAL NUMBER" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.SerialNumber, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="HARDWARE ID" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.HardwareId, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />

                            <TextBlock Text="IP ADDRESS" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.Address, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />

                            <TextBlock Text="HOSTNAME" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Hostname, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource PrimaryTextBrush}" 
                                       Margin="0,2,0,16" FontSize="14" />

                            <TextBlock Text="SERVICE ADDRESS" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.ServiceAddress, FallbackValue='-'}" 
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource AccentBrush}" 
                                       Margin="0,2,0,16" FontSize="12" TextWrapping="Wrap"
                                       FontFamily="{StaticResource MonoFont}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Capabilities Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Capabilities" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />
                    <WrapPanel>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#15607D8B" />
                                    <Setter Property="BorderBrush" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Device.Capabilities.HasMedia}" Value="True">
                                            <Setter Property="Background" Value="#1500D4AA" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Media" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Device.Capabilities.HasMedia}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#15607D8B" />
                                    <Setter Property="BorderBrush" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Device.Capabilities.HasPtz}" Value="True">
                                            <Setter Property="Background" Value="#1500D4AA" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="PTZ" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Device.Capabilities.HasPtz}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#15607D8B" />
                                    <Setter Property="BorderBrush" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Device.Capabilities.HasEvents}" Value="True">
                                            <Setter Property="Background" Value="#1500D4AA" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Events" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Device.Capabilities.HasEvents}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#15607D8B" />
                                    <Setter Property="BorderBrush" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Device.Capabilities.HasImaging}" Value="True">
                                            <Setter Property="Background" Value="#1500D4AA" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Imaging" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Device.Capabilities.HasImaging}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#15607D8B" />
                                    <Setter Property="BorderBrush" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Device.Capabilities.HasAnalytics}" Value="True">
                                            <Setter Property="Background" Value="#1500D4AA" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Analytics" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Device.Capabilities.HasAnalytics}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Date/Time Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System Date &amp; Time" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DEVICE TIME (UTC)" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding DateTimeInfo.DeviceTime, StringFormat='yyyy-MM-dd HH:mm:ss', FallbackValue='-'}" 
                                       Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TIME ZONE" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Text="{Binding DateTimeInfo.TimeZone, FallbackValue='-'}" 
                                       Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NTP SYNC" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                            <TextBlock Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="No" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DateTimeInfo.IsNtp}" Value="True">
                                                <Setter Property="Text" Value="Yes" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Hostname & Device Actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Hostname Card -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Set Hostname" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                        <Button Style="{StaticResource PrimaryButton}" Content="Apply"
                                Command="{Binding SetHostnameCommand}" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Device Actions -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Device Actions" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />
                        <Button Style="{StaticResource SecondaryButton}" Content="Reboot Device"
                                Command="{Binding RebootCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch" />
                        <Button Style="{StaticResource DangerButton}" Content="Factory Reset"
                                Command="{Binding FactoryResetCommand}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status -->
            <Border Margin="0,16,0,0" Padding="12,8" 
                    Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
