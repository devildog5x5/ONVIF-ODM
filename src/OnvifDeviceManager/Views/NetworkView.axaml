<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OnvifDeviceManager.ViewModels"
             xmlns:views="using:OnvifDeviceManager.Views"
             x:Class="OnvifDeviceManager.Views.NetworkView"
             x:DataType="vm:NetworkViewModel">

    <Panel>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding Device, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Margin="24">
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Network Configuration" Classes="header" />
                    <TextBlock Text="View network settings of the connected device" Classes="body" Margin="0,4,0,0" />
                </StackPanel>
                <Button Classes="secondary" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Content="Refresh" Command="{Binding RefreshCommand}" />
            </Grid>

            <Grid ColumnDefinitions="*,16,*">
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <TextBlock Text="IPv4 Configuration" Classes="subheader" Margin="0,0,0,16" />
                        <TextBlock Text="IP ADDRESS" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.IpAddress, FallbackValue='-'}" Foreground="White" FontSize="16" Margin="0,2,0,16" />
                        <TextBlock Text="SUBNET MASK" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.SubnetMask, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />
                        <TextBlock Text="GATEWAY" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.Gateway, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />
                        <TextBlock Text="DHCP" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.IsDhcp}" Foreground="White" FontSize="14" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Additional Settings" Classes="subheader" Margin="0,0,0,16" />
                        <TextBlock Text="MAC ADDRESS" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.MacAddress, FallbackValue='-'}" Classes="mono" Margin="0,2,0,16" />
                        <TextBlock Text="DNS PRIMARY" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.PrimaryDns, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />
                        <TextBlock Text="DNS SECONDARY" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.SecondaryDns, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />
                        <TextBlock Text="HTTP PORT" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.HttpPort, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />
                        <TextBlock Text="RTSP PORT" Classes="caption" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.RtspPort, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Margin="0,16,0,0" Padding="12,8" Background="#1E2A4A" CornerRadius="8">
                <TextBlock Text="{Binding StatusText}" Classes="caption" />
            </Border>
        </StackPanel>
    </ScrollViewer>
        <views:NoDevicePrompt IsVisible="{Binding Device, Converter={x:Static ObjectConverters.IsNull}}" />
    </Panel>
</UserControl>
