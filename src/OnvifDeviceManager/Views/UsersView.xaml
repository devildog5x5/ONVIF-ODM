<UserControl x:Class="OnvifDeviceManager.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="User Management" Style="{StaticResource HeaderText}" />
                <TextBlock Text="Manage device user accounts and access levels" 
                           Style="{StaticResource BodyText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Content="Refresh" Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- Users List -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Device Users" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />

                <DataGrid Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          CellStyle="{StaticResource ModernDataGridCell}"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="*" />
                        <DataGridTextColumn Header="USER LEVEL" Binding="{Binding UserLevel}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Users.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                               Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="No users loaded" Style="{StaticResource BodyText}" 
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Create User -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Create New User" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Username" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                    <TextBlock Grid.Column="2" Text="Password" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                    <TextBlock Grid.Column="4" Text="User Level" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                    <TextBox Grid.Row="1" Style="{StaticResource ModernTextBox}" 
                             Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource ModernTextBox}" 
                             Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Grid.Row="1" Grid.Column="4" Style="{StaticResource ModernComboBox}" 
                              ItemsSource="{Binding UserLevels}" SelectedItem="{Binding SelectedUserLevel}" />

                    <Button Grid.Row="1" Grid.Column="6" Style="{StaticResource PrimaryButton}" 
                            Content="Create" Command="{Binding CreateUserCommand}" />
                    <Button Grid.Row="1" Grid.Column="8" Style="{StaticResource DangerButton}" 
                            Content="Delete Selected" Command="{Binding DeleteUserCommand}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8" 
                Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
        </Border>
    </Grid>
</UserControl>
