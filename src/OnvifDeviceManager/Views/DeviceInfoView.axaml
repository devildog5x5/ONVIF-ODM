<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OnvifDeviceManager.ViewModels"
             x:Class="OnvifDeviceManager.Views.DeviceInfoView"
             x:DataType="vm:DeviceInfoViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Device Information" Classes="header" />
            <TextBlock Text="View detailed information about the connected device" Classes="body" Margin="0,4,0,24" />

            <!-- Device Details -->
            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Device Details" Classes="subheader" />
                        <Button Classes="secondary" HorizontalAlignment="Right"
                                Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="MANUFACTURER" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.Manufacturer, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />

                            <TextBlock Text="MODEL" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.Model, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />

                            <TextBlock Text="FIRMWARE VERSION" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.FirmwareVersion, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />

                            <TextBlock Text="SERIAL NUMBER" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.SerialNumber, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="HARDWARE ID" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.HardwareId, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />

                            <TextBlock Text="IP ADDRESS" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.Address, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />

                            <TextBlock Text="HOSTNAME" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Hostname, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,16" />

                            <TextBlock Text="SERVICE ADDRESS" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding Device.ServiceAddress, FallbackValue='-'}" Classes="mono" Margin="0,2,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Capabilities -->
            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Capabilities" Classes="subheader" Margin="0,0,0,16" />
                    <WrapPanel>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8" BorderThickness="1"
                                Background="#1500D4AA" BorderBrush="#00D4AA"
                                IsVisible="{Binding Device.Capabilities.HasMedia}">
                            <TextBlock Text="Media" FontSize="12" Foreground="#00D4AA" />
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8" BorderThickness="1"
                                Background="#1500D4AA" BorderBrush="#00D4AA"
                                IsVisible="{Binding Device.Capabilities.HasPtz}">
                            <TextBlock Text="PTZ" FontSize="12" Foreground="#00D4AA" />
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8" BorderThickness="1"
                                Background="#1500D4AA" BorderBrush="#00D4AA"
                                IsVisible="{Binding Device.Capabilities.HasEvents}">
                            <TextBlock Text="Events" FontSize="12" Foreground="#00D4AA" />
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8" BorderThickness="1"
                                Background="#1500D4AA" BorderBrush="#00D4AA"
                                IsVisible="{Binding Device.Capabilities.HasImaging}">
                            <TextBlock Text="Imaging" FontSize="12" Foreground="#00D4AA" />
                        </Border>
                        <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,8" BorderThickness="1"
                                Background="#1500D4AA" BorderBrush="#00D4AA"
                                IsVisible="{Binding Device.Capabilities.HasAnalytics}">
                            <TextBlock Text="Analytics" FontSize="12" Foreground="#00D4AA" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Date/Time -->
            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System Date &amp; Time" Classes="subheader" Margin="0,0,0,16" />
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel>
                            <TextBlock Text="DEVICE TIME (UTC)" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding DateTimeInfo.DeviceTime, StringFormat='yyyy-MM-dd HH:mm:ss', FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TIME ZONE" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding DateTimeInfo.TimeZone, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NTP SYNC" Classes="caption" FontWeight="Bold" />
                            <TextBlock Text="{Binding DateTimeInfo.IsNtp, FallbackValue='-'}" Foreground="White" FontSize="14" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Hostname & Actions -->
            <Grid ColumnDefinitions="*,16,*">
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Set Hostname" Classes="subheader" Margin="0,0,0,12" />
                        <TextBox Classes="modern" Text="{Binding Hostname}" Margin="0,0,0,12" />
                        <Button Classes="primary" Content="Apply" Command="{Binding SetHostnameCommand}" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Device Actions" Classes="subheader" Margin="0,0,0,12" />
                        <Button Classes="secondary" Content="Reboot Device" Command="{Binding RebootCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch" />
                        <Button Classes="danger" Content="Factory Reset" Command="{Binding FactoryResetCommand}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Margin="0,16,0,0" Padding="12,8" Background="#1E2A4A" CornerRadius="8">
                <TextBlock Text="{Binding StatusText}" Classes="caption" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
