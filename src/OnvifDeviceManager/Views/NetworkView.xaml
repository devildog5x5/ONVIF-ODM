<UserControl x:Class="OnvifDeviceManager.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Network Configuration" Style="{StaticResource HeaderText}" />
                    <TextBlock Text="View network settings of the connected device" 
                               Style="{StaticResource BodyText}" Margin="0,4,0,0" />
                </StackPanel>
                <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Content="Refresh" Command="{Binding RefreshCommand}" />
            </Grid>

            <!-- Network Info -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- IPv4 Settings -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="IPv4 Configuration" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />

                        <TextBlock Text="IP ADDRESS" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.IpAddress, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="16" Margin="0,2,0,16" />

                        <TextBlock Text="SUBNET MASK" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.SubnetMask, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,16" />

                        <TextBlock Text="GATEWAY" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.Gateway, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,16" />

                        <TextBlock Text="DHCP" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Disabled" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NetworkConfig.IsDhcp}" Value="True">
                                            <Setter Property="Text" Value="Enabled" />
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Additional Settings -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Additional Settings" Style="{StaticResource SubHeaderText}" Margin="0,0,0,16" />

                        <TextBlock Text="MAC ADDRESS" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.MacAddress, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" 
                                   FontFamily="{StaticResource MonoFont}" Margin="0,2,0,16" />

                        <TextBlock Text="DNS PRIMARY" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.PrimaryDns, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,16" />

                        <TextBlock Text="DNS SECONDARY" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.SecondaryDns, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,16" />

                        <TextBlock Text="HTTP PORT" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.HttpPort, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,16" />

                        <TextBlock Text="RTSP PORT" Style="{StaticResource CaptionText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetworkConfig.RtspPort, FallbackValue='-'}" 
                                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status -->
            <Border Margin="0,16,0,0" Padding="12,8" 
                    Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
