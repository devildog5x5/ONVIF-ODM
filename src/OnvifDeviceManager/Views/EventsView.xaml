<UserControl x:Class="OnvifDeviceManager.Views.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Device Events" Style="{StaticResource HeaderText}" />
            <TextBlock Text="Monitor real-time events from the connected device" 
                       Style="{StaticResource BodyText}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleSubscriptionCommand}" 
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                   VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE768;" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubscribed}" Value="True">
                                            <Setter Property="Text" Value="&#xE71A;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Subscribe" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubscribed}" Value="True">
                                            <Setter Property="Text" Value="Unsubscribe" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ClearEventsCommand}" Content="Clear" />

                <TextBlock Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock.Text>
                        <Binding Path="Events.Count" StringFormat="{}{0} event(s)" />
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Events Log -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Event Log" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />

                <DataGrid Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          CellStyle="{StaticResource ModernDataGridCell}"
                          ItemsSource="{Binding Events}"
                          SelectedItem="{Binding SelectedEvent}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIMESTAMP" 
                                            Binding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Width="120" />
                        <DataGridTextColumn Header="SEVERITY" Binding="{Binding Severity}" Width="80" />
                        <DataGridTextColumn Header="TOPIC" Binding="{Binding Topic}" Width="*" />
                        <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="150" />
                        <DataGridTextColumn Header="DATA" Binding="{Binding Data}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Events.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                               Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="No events recorded" Style="{StaticResource BodyText}" 
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                    <TextBlock Text="Subscribe to start receiving device events" Style="{StaticResource CaptionText}" 
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8" 
                Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
        </Border>
    </Grid>
</UserControl>
