<UserControl x:Class="OnvifDeviceManager.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OnvifDeviceManager.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Media Profiles" Style="{StaticResource HeaderText}" />
                <TextBlock Text="View and manage media streaming profiles" 
                           Style="{StaticResource BodyText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Content="Refresh" Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- Profiles Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Profile List -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Profiles" Style="{StaticResource SubHeaderText}" Margin="0,0,0,12" />

                    <ListBox Grid.Row="1" Style="{StaticResource ModernListBox}" 
                             ItemContainerStyle="{StaticResource ModernListBoxItem}"
                             ItemsSource="{Binding Profiles}" 
                             SelectedItem="{Binding SelectedProfile}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding VideoEncoder.Summary, FallbackValue='No encoder info'}" 
                                               Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border CornerRadius="3" Padding="6,2" Background="#1500D4AA" Margin="0,0,4,0"
                                                Visibility="{Binding IsPtzEnabled, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="PTZ" FontSize="10" Foreground="{StaticResource AccentBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Profile Details -->
            <Border Grid.Column="2" Style="{StaticResource Card}"
                    Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Profile Details" Style="{StaticResource SubHeaderText}" Margin="0,0,0,20" />

                        <!-- General -->
                        <TextBlock Text="GENERAL" Style="{StaticResource CaptionText}" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Name" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.Name}" Margin="0,4" 
                                       Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock Grid.Row="1" Text="Token" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedProfile.Token}" Margin="0,4"
                                       Foreground="{StaticResource PrimaryTextBrush}" FontFamily="{StaticResource MonoFont}" FontSize="12" />

                            <TextBlock Grid.Row="2" Text="PTZ Enabled" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4" Foreground="{StaticResource PrimaryTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="No" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProfile.IsPtzEnabled}" Value="True">
                                                <Setter Property="Text" Value="Yes" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Video Encoder -->
                        <TextBlock Text="VIDEO ENCODER" Style="{StaticResource CaptionText}" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,20"
                              Visibility="{Binding SelectedProfile.VideoEncoder, Converter={StaticResource NullToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Encoding" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.Encoding}" Margin="0,4"
                                       Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock Grid.Row="1" Text="Resolution" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.Resolution}" Margin="0,4"
                                       Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock Grid.Row="2" Text="Frame Rate" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4"
                                       Text="{Binding SelectedProfile.VideoEncoder.FrameRate, StringFormat='{}{0} fps'}"
                                       Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock Grid.Row="3" Text="Bitrate" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,4"
                                       Text="{Binding SelectedProfile.VideoEncoder.BitRate, StringFormat='{}{0} kbps'}"
                                       Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock Grid.Row="4" Text="Quality" Style="{StaticResource CaptionText}" Margin="0,4" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedProfile.VideoEncoder.Quality}" Margin="0,4"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                        </Grid>

                        <!-- Stream URIs -->
                        <TextBlock Text="STREAM URIS" Style="{StaticResource CaptionText}" FontWeight="Bold" Margin="0,0,0,8" />
                        <StackPanel>
                            <TextBlock Text="RTSP Stream" Style="{StaticResource CaptionText}" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding SelectedProfile.StreamUri, FallbackValue='N/A'}" 
                                       Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}" 
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />

                            <TextBlock Text="Snapshot" Style="{StaticResource CaptionText}" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding SelectedProfile.SnapshotUri, FallbackValue='N/A'}" 
                                       Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}" 
                                       FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12,8" 
                Background="{StaticResource CardBrush}" CornerRadius="{StaticResource MediumCornerRadius}">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
        </Border>
    </Grid>
</UserControl>
